################################
# MODIFICATIONS POUR LE PROJET #
################################

# On bloque le dossier temporaire de CakePHP mais on garde la structure
/app/tmp/*
!/app/tmp/cache/
!/app/tmp/logs/
# Sécurité pour ne pas effacer les fichiers qui forcent la création des dossiers
!**/cache/**/*.gitkeep
!**/logs/**/*.gitkeep

# Sécurité : On ignore les identifiants BDD réels
/app/Config/database.php

# On bloque les dossiers tiers et serveurs locaux
/app/Vendor/
/vendor/
/cgi-bin/

# Vos extensions globales (APK, ZIP, BAK, MMDB...)
*.apk
*.zip
*.bak
*.mmdb
*.tar.gz
*.rar
*.exe
*.log
*.sql
*.sqlite